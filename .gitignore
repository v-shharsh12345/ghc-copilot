# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor files
.vscode/settings.json
*.swp
*.swo

# User-specific config (created from .template.yaml files)
config/user-context.yaml
config/user-context.template copy.yaml

# Sensitive config
# **/*-secrets.yaml
# **/*-credentials.yaml

# ── Production data outputs (never share — contain real revenue/sales data) ──
*.xlsx
scripts/*.csv
excel_content.json
excel_detailed.txt
excel_readable.txt

# ── Personal memory (keep templates, exclude real notes) ──
memory/MEMORY.md
memory/daily/
memory/session/
memory/knowledgebase/
!memory/MEMORY.template.md

# ── Local/temp artifacts ──
.tmp/
.playwright-mcp/
scripts/live-decoded-*
scripts/decoded-*
scripts/*.json
