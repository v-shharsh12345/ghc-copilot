#!/bin/sh
#
# Pre-push hook: blocks direct pushes to main from unauthorized users.
# Only v-arloonker@microsoft.com can push directly to main.
# All others must use a pull request.

ALLOWED_EMAIL="v-arloonker@microsoft.com"
PROTECTED_BRANCH="main"

current_email=$(git config user.email)
current_branch=$(git symbolic-ref --short HEAD 2>/dev/null)

while read local_ref local_sha remote_ref remote_sha; do
    if echo "$remote_ref" | grep -qE "refs/heads/${PROTECTED_BRANCH}$"; then
        if [ "$current_email" != "$ALLOWED_EMAIL" ]; then
            echo ""
            echo "========================================================"
            echo "  BLOCKED: Direct push to '$PROTECTED_BRANCH' denied."
            echo "  Only $ALLOWED_EMAIL may push directly."
            echo "  Please create a pull request instead."
            echo "========================================================"
            echo ""
            exit 1
        fi
    fi
done

exit 0
